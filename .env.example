# Server-only: used in Next.js Route Handlers for Directions, Distance Matrix, Places APIs
# Never exposed to the browser
GOOGLE_SERVER_KEY=your_google_server_key_here

# Client-safe: used only for map rendering
# Must be restricted to HTTP Referrers in Google Console (localhost:3000/*, yourdomain.com/*)
NEXT_PUBLIC_MAPS_JS_KEY=your_maps_js_key_here

# TfL Unified API key (free registration at https://api-portal.tfl.gov.uk/)
# Without registration: 50 req/hr; with free registration: 500 req/min
TFL_APP_KEY=your_tfl_app_key_here
